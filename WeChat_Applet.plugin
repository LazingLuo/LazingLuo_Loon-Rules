#!name=微信小程序广告位拦截-极限测试
#!desc=微信小程序广告过滤规则集合；当前规则：每日抽奖
#!author=OpenAI
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/WeChat.png

[Rewrite]
# ================================
# 小程序：每日抽奖
# 说明：
# 1. 实测有效版本
# 2. 通过返回空成功响应，伪装广告加载完成，跳过刷广告
# 3. 保留抽奖流程，不加载广告素材
# ================================

^https?:\/\/minorshort\.weixin\.qq\.com\/mmtls\/.* response-body=""
^https?:\/\/extshort\.weixin\.qq\.com\/mmtls\/.* response-body=""
^https?:\/\/wximg\.wxs\.qq\.com\/.*\/ads_svp_video__.* response-body=""
^https?:\/\/wximg\.wxs\.qq\.com\/.*\/snscosdownload\/SZ\/reserved\/.* response-body=""

[MITM]
hostname = minorshort.weixin.qq.com, extshort.weixin.qq.com, wximg.wxs.qq.com
