#!name=微信小程序广告位拦截-极限测试
#!desc=微信小程序广告过滤规则集合；当前规则：每日抽奖
#!author=OpenAI
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/WeChat.png

[Rewrite]
# ================================
# 小程序：每日抽奖
# 说明：
# 1. 实测有效版本
# 2. 通过拦截 minorshort/extshort 的 mmtls 以及 wximg 广告素材实现去广告
# 3. 该小程序广告资源很多，规则目标是保留抽奖流程，跳过刷广告
# ================================

^https?:\/\/minorshort\.weixin\.qq\.com\/mmtls\/.* - reject-200
^https?:\/\/extshort\.weixin\.qq\.com\/mmtls\/.* - reject-200
^https?:\/\/wximg\.wxs\.qq\.com\/.*\/ads_svp_video__.* - reject
^https?:\/\/wximg\.wxs\.qq\.com\/.*\/snscosdownload\/SZ\/reserved\/.* - reject

[MITM]
hostname = minorshort.weixin.qq.com, extshort.weixin.qq.com, wximg.wxs.qq.com
