#!name = 小红书 去开屏广告
#!desc = 通过修改 splash_config 响应时间使开屏广告失效
# 感谢kelee提供的插件，以及写得那么完整的js
[Script]
http-response ^https:\/\/edith\.xiaohongshu\.com\/api\/sns\/v\d\/system_service\/splash_config requires-body=1,timeout=20,script-path=https://kelee.one/Resource/JavaScript/RedPaper/RedPaper_remove_ads.js,tag=小红书_开屏去广告
http-response ^https?:\/\/edith\.xiaohongshu\.com\/api\/sns\/v\d\/homefeed\? requires-body=1,script-path=https://kelee.one/Resource/JavaScript/RedPaper/RedPaper_remove_ads.js,tag=小红书_信息流净化
http-response ^https?:\/\/edith\.xiaohongshu\.com\/api\/sns\/v\d\/system_service\/config\? requires-body=1,script-path=https://kelee.one/Resource/JavaScript/RedPaper/RedPaper_remove_ads.js,tag=小红书_配置净化

[MITM]
hostname = edith.xiaohongshu.com
